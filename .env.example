# MongoDB
MONGODB_URI=
MONGODB_DB=

# PostgreSQL
POSTGRES_URL=

# RAG
RAG_ENABLED=true
RAG_MONGODB_URI=
RAG_MONGODB_DB=
RAG_SOURCE=local
RAG_DOCS_DIR=
RAG_COLLECTION=criminal
RAG_CATEGORY=criminal
RAG_FILTER_CATEGORY=
RAG_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=5
RAG_MIN_SCORE=0.65
RAG_TIMEOUT_MS=8000
CLASSIFIER_ENABLED=true
CLASSIFIER_BYPASS_ON_CRIMINAL_KEYWORDS=true
CLASSIFIER_TIMEOUT_MS=12000
GENERATION_TIMEOUT_MS=60000
# Set timeout to 0 to disable local timeout wrappers and wait for Ollama completion.
# Example: CLASSIFIER_TIMEOUT_MS=0 and GENERATION_TIMEOUT_MS=0
CRIMINAL_MODEL_FALLBACK=aslaw-general
CRIMINAL_MODEL_FALLBACK_AFTER_MS=60000
SKIP_RAG_FOR_CRIMINAL=true
DEFAULT_NUM_PREDICT=600
CRIMINAL_NUM_PREDICT=350
REDUCED_NUM_PREDICT=220
RAG_MAX_CONTEXT_CHARS=9000
RAG_CHUNK_SIZE=3500
RAG_CHUNK_OVERLAP=600
RAG_VECTOR_INDEX=rag_vector_index
RAG_FALLBACK_SCAN_LIMIT=2000
CRIMINAL_KEYWORD_OVERRIDE=true

# Azure Blob source for RAG ingestion
AZURE_STORAGE_NAME=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_PREFIX=
